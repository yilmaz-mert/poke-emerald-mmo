// server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Pokemon {
  id               Int               @id @default(autoincrement())
  name             String
  height           Int?
  weight           Int?
  baseExperience   Int?              @map("base_experience")
  spriteUrl        String?           @map("sprite_url")
  animatedUrl      String?           @map("animated_url")
  artworkUrl       String?           @map("artwork_url")  
  evolutionChainId Int?              @map("evolution_chain_id")
  flavorText       String?           @map("flavor_text") // Açıklama yazısı
  criesUrl         String?           @map("cries_url")   // Ses dosyası yolu
  stats            PokemonStats?
  types            PokemonType[]
  abilities        PokemonAbility[]
  capturedBy       CapturedPokemon[]
  @@index([name]) 
}

model Type {
  id       Int           @id @default(autoincrement())
  name     String        @unique
  pokemons PokemonType[]
}

model PokemonType {
  pokemon   Pokemon @relation(fields: [pokemonId], references: [id])
  pokemonId Int
  type      Type    @relation(fields: [typeId], references: [id])
  typeId    Int

  @@id([pokemonId, typeId])
}

model PokemonStats {
  id              Int     @id @default(autoincrement())
  hp              Int     @default(0)
  attack          Int     @default(0)
  defense         Int     @default(0)
  special_attack  Int     @default(0) // Yeni eklendi
  special_defense Int     @default(0) // Yeni eklendi
  speed           Int     @default(0) // Yeni eklendi
  pokemon         Pokemon @relation(fields: [pokemonId], references: [id])
  pokemonId       Int     @unique
}

model Ability {
  id       Int              @id @default(autoincrement())
  name     String           @unique
  pokemons PokemonAbility[]
}

model PokemonAbility {
  pokemon   Pokemon @relation(fields: [pokemonId], references: [id])
  pokemonId Int
  ability   Ability @relation(fields: [abilityId], references: [id])
  abilityId Int
  isHidden  Boolean @default(false) @map("is_hidden") // Gizli yetenek mi?

  @@id([pokemonId, abilityId])
}

model CapturedPokemon {
  id         Int      @id @default(autoincrement())
  userId     String   // İleride auth eklenince UUID olacak
  pokemon    Pokemon  @relation(fields: [pokemonId], references: [id])
  pokemonId  Int
  nickname   String?
  level      Int      @default(1)
  capturedAt DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  
  // İleride eklenebilecek ilişkiler:
  // caughtPokemons UserPokemon[]
}